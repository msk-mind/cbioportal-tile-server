# ── S3 / Dell ECS ────────────────────────────────────────────────────────────
AWS_ENDPOINT_URL=http://pmindecs.mskcc.org:9020
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# ── Databricks — patient/slide metadata ─────────────────────────────────────
DATABRICKS_HOST=https://msk-mode-prod.cloud.databricks.com
DATABRICKS_TOKEN=your-databricks-pat
DATABRICKS_WAREHOUSE_ID=0b49b7d78734ad5c

# ── CORS (add viewer and cBioPortal origins) ─────────────────────────────────
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,https://cbioportal.org,https://www.cbioportal.org

# ── Tuning (dev-friendly defaults) ──────────────────────────────────────────
PATIENT_CACHE_TTL=60        # 1 min (set 86400 in prod)
MAX_OPEN_SLIDES=8           # small for local dev
REDIS_MAXMEMORY=256mb
APP_MEMORY_LIMIT=4g
SERVER_PORT=8081
